{
  "rewrites": [
    { "source": "/api/login", "destination": "/api/login.js" },
    { "source": "/api/users", "destination": "/api/users.js" },
    { "source": "/api/sensor", "destination": "/api/sensor.js" },
    { "source": "/api/get-sensor", "destination": "/api/get-sensor.js" },
    { "source": "/(.*)", "destination": "/client/$1" }
  ]
}