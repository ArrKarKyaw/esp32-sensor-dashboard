{
  "version": 2,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/server/server.js"
    },
    {
      "source": "/users",
      "destination": "/server/server.js"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}