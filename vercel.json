{
  "version": 2,
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/login",
      "destination": "api/server.js"
    },
    {
      "source": "/users",
      "destination": "api/server.js"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "api/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}